# Copy to .env.local (never commit)

LEMON_MOCK=1
LEMON_API_KEY=
LEMON_STORE_ID=
LEMON_WEBHOOK_SECRET=mock_webhook_secret
LEMON_VARIANT_DEVDOCK=
LEMON_VARIANT_DEVMAIL=
LEMON_VARIANT_DEVSQL=
LEMON_VARIANT_DEVCHECK=

# Postgres (required for webhooks + license portal)
DATABASE_URL=postgres://user:pass@host:5432/postgres
# Set DATABASE_SSL=1 if the server requires TLS
# DATABASE_SSL=1

# Session cookie signing (falls back to LEMON_WEBHOOK_SECRET)
SESSION_SECRET=change-me-to-a-long-random-string

# Public site URL (used for GitHub OAuth callback). Optional in local
# next: hosts from the request are used. Set in production.
# APP_URL=https://devsuites.dev

# GitHub OAuth (https://github.com/settings/developers → OAuth Apps)
# Authorization callback URL: {APP_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin panel (secret URL — never use /admin publicly)
ADMIN_PATH=ops-change-me
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
